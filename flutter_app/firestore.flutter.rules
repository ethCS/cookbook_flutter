rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeString(value, min, max) {
      return value is string
        && value.size() >= min
        && value.size() <= max
        && !value.matches('.*[<>`].*')
        && !value.matches('(?i).*(javascript\\s*:|vbscript\\s*:|data\\s*:\\s*text/html|on[a-z]+\\s*=|<\\s*/?\\s*(script|iframe|svg|img|object|embed)).*');
    }

    function optionalString(value, max) {
      return value == null || safeString(value, 0, max);
    }

    function optionalInt(value, min, max) {
      return value == null || (value is int && value >= min && value <= max);
    }

    function optionalList(value, maxItems) {
      return value == null || (value is list && value.size() <= maxItems);
    }

    function safeHttpsUrl(value, min, max) {
      return value is string
        && value.size() >= min
        && value.size() <= max
        && value.matches('^https://[^\\s<>"`]+$');
    }

    function safeStringList(value, minItems, maxItems, maxLength) {
      return value is list
        && value.size() >= minItems
        && value.size() <= maxItems
        && (value.size() < 1 || safeString(value[0], 1, maxLength))
        && (value.size() < 2 || safeString(value[1], 1, maxLength))
        && (value.size() < 3 || safeString(value[2], 1, maxLength))
        && (value.size() < 4 || safeString(value[3], 1, maxLength))
        && (value.size() < 5 || safeString(value[4], 1, maxLength))
        && (value.size() < 6 || safeString(value[5], 1, maxLength))
        && (value.size() < 7 || safeString(value[6], 1, maxLength))
        && (value.size() < 8 || safeString(value[7], 1, maxLength))
        && (value.size() < 9 || safeString(value[8], 1, maxLength))
        && (value.size() < 10 || safeString(value[9], 1, maxLength))
        && (value.size() < 11 || safeString(value[10], 1, maxLength))
        && (value.size() < 12 || safeString(value[11], 1, maxLength))
        && (value.size() < 13 || safeString(value[12], 1, maxLength))
        && (value.size() < 14 || safeString(value[13], 1, maxLength))
        && (value.size() < 15 || safeString(value[14], 1, maxLength))
        && (value.size() < 16 || safeString(value[15], 1, maxLength))
        && (value.size() < 17 || safeString(value[16], 1, maxLength))
        && (value.size() < 18 || safeString(value[17], 1, maxLength))
        && (value.size() < 19 || safeString(value[18], 1, maxLength))
        && (value.size() < 20 || safeString(value[19], 1, maxLength))
        && (value.size() < 21 || safeString(value[20], 1, maxLength))
        && (value.size() < 22 || safeString(value[21], 1, maxLength))
        && (value.size() < 23 || safeString(value[22], 1, maxLength))
        && (value.size() < 24 || safeString(value[23], 1, maxLength))
        && (value.size() < 25 || safeString(value[24], 1, maxLength));
    }

    match /users/{userId} {
      allow read: if owner(userId);

      allow create, update: if owner(userId)
        && request.resource.data.keys().hasOnly(['username', 'email', 'createdAt'])
        && safeString(request.resource.data.username, 1, 40)
        && safeString(request.resource.data.email, 5, 120);

      allow delete: if false;

      match /favorites/{recipeId} {
        allow read, delete: if owner(userId);

        allow create, update: if owner(userId)
          && request.resource.data.keys().hasOnly(['recipeId', 'title', 'image', 'category', 'source', 'addedAt'])
          && safeString(request.resource.data.recipeId, 1, 40)
          && safeString(request.resource.data.title, 1, 120)
          && safeHttpsUrl(request.resource.data.image, 8, 500)
          && optionalString(request.resource.data.category, 60)
          && request.resource.data.source == 'themealdb';
      }

      match /customRecipes/{recipeDocId} {
        allow read, delete: if owner(userId);

        allow create, update: if owner(userId)
          && request.resource.data.keys().hasOnly([
            'title',
            'description',
            'ingredients',
            'instructions',
            'prepTime',
            'servings',
            'tags',
            'createdAt'
          ])
          && safeString(request.resource.data.title, 1, 80)
          && optionalString(request.resource.data.description, 180)
          && safeStringList(request.resource.data.ingredients, 1, 25, 100)
          && safeString(request.resource.data.instructions, 1, 4000)
          && optionalInt(request.resource.data.prepTime, 1, 1440)
          && optionalInt(request.resource.data.servings, 1, 50)
          && optionalList(request.resource.data.tags, 8)
          && safeStringList(request.resource.data.tags, 0, 8, 20);
      }
    }
  }
}
